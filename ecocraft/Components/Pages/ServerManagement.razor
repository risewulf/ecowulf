	private async Task PersistCalorieCostPolicy()
	{
		var currentServer = ContextService.CurrentServer;
		if (currentServer is null)
		{
			return;
		}

		// With lock enabled, an empty locked value falls back to 0.
		if (_isCalorieCostLocked && _lockedCalorieCost is null)
		{
			_lockedCalorieCost = 0;
		}

		currentServer.IsCalorieCostLocked = _isCalorieCostLocked;
		currentServer.LockedCalorieCost = _lockedCalorieCost;
		currentServer.CalorieCostMin = _calorieCostMin;
		currentServer.CalorieCostDefault = _calorieCostDefault;
		currentServer.CalorieCostMax = _calorieCostMax;

		try
		{
			await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context =>
			{
				ServerDbService.UpdateCalorieCostPolicy(context, currentServer);

				if (currentServer.IsCalorieCostLocked && currentServer.LockedCalorieCost is not null)
				{
					await context.UserSettings
						.Where(us => us.DataContext.UserServer.ServerId == currentServer.Id)
						.ExecuteUpdateAsync(s => s
							.SetProperty(x => x.CalorieCost, currentServer.LockedCalorieCost.Value));
				}
			});

			if (currentServer.IsCalorieCostLocked && currentServer.LockedCalorieCost is not null)
			{
				foreach (var userServer in currentServer.UserServers)
				{
					foreach (var dataContext in userServer.DataContexts)
					{
						var userSetting = dataContext.UserSettings.FirstOrDefault();
						if (userSetting is not null)
						{
							userSetting.CalorieCost = currentServer.LockedCalorieCost.Value;
						}
					}
				}
			}
		}
		catch (Exception ex)
		{
			Snackbar.Add($"{LocalizationService.GetTranslation("ServerManagement.CalorieCostPolicy.Snackbar.SaveError")}: {ex.Message}", Severity.Error);
		}
	}

