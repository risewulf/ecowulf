	private async Task RetrieveData()
	{
		var refreshedServer = await ServerDbService.GetByIdAsync(ContextService.CurrentServer!.Id);
		if (refreshedServer is not null)
		{
			ContextService.CurrentServer!.Name = refreshedServer.Name;
			ContextService.CurrentServer.UserServers = refreshedServer.UserServers;
			ContextService.CurrentServer.EcoServerId = refreshedServer.EcoServerId;
			ContextService.CurrentServer.JoinCode = refreshedServer.JoinCode;
			ContextService.CurrentServer.ApiKey = refreshedServer.ApiKey;
			ContextService.CurrentServer.IsCalorieCostLocked = refreshedServer.IsCalorieCostLocked;
			ContextService.CurrentServer.LockedCalorieCost = refreshedServer.LockedCalorieCost;
			ContextService.CurrentServer.CalorieCostMin = refreshedServer.CalorieCostMin;
			ContextService.CurrentServer.CalorieCostDefault = refreshedServer.CalorieCostDefault;
			ContextService.CurrentServer.CalorieCostMax = refreshedServer.CalorieCostMax;
			ContextService.CurrentServer.IsMarginLocked = refreshedServer.IsMarginLocked;
			ContextService.CurrentServer.LockedMargin = refreshedServer.LockedMargin;
			ContextService.CurrentServer.MarginMin = refreshedServer.MarginMin;
			ContextService.CurrentServer.MarginDefault = refreshedServer.MarginDefault;
			ContextService.CurrentServer.MarginMax = refreshedServer.MarginMax;
			ContextService.CurrentServer.LastDataUploadTime = refreshedServer.LastDataUploadTime;
		}

		LoadCalorieCostPolicyFromCurrentServer();
		LoadMarginPolicyFromCurrentServer();

		if (ContextService.CurrentServerData is null)
		{
			_stats.Clear();
			_isLoadingData = true;
			StateHasChanged();

			ContextService.CurrentServerData = await ServerDbService.GetServerWithData(ContextService.CurrentServer!.Id);

			_isLoadingData = false;
		}

		RecalculateStats();

		StateHasChanged();
	}

	private void LoadCalorieCostPolicyFromCurrentServer()
	{
		_isCalorieCostLocked = ContextService.CurrentServer?.IsCalorieCostLocked ?? false;
		_lockedCalorieCost = ContextService.CurrentServer?.LockedCalorieCost;
		_calorieCostMin = ContextService.CurrentServer?.CalorieCostMin;
		_calorieCostDefault = ContextService.CurrentServer?.CalorieCostDefault;
		_calorieCostMax = ContextService.CurrentServer?.CalorieCostMax;
