	private async Task OnClearDefaultPrices(List<ItemOrTag> itemOrTags)
	{
		var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", LocalizationService.GetTranslation("ServerManagement.Confirm.ClearAllDefault"));
		if (!confirmed) return;

		await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
		{
			foreach (var itemOrTag in itemOrTags)
			{
				itemOrTag.DefaultPrice = null;
				ItemOrTagDbService.UpdatePrices(context, itemOrTag);
			}

			return Task.CompletedTask;
		});

		// In lock mode, the Default column shows the locked value.
		if (_isCalorieCostLocked)
		{
			_lockedCalorieCost = null;
		}
		else
		{
			_calorieCostDefault = null;
		}

		if (_isMarginLocked)
		{
			_lockedMargin = null;
		}
		else
		{
			_marginDefault = null;
		}

		await PersistCalorieCostPolicy();
		await PersistMarginPolicy();
		await RefreshCurrentServerDataAndStats();
		await RefreshItemsTableAsync();
	}

