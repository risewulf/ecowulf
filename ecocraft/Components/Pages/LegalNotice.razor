@page "/legal"

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-6">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h4" GutterBottom="true">Mentions légales</MudText>
        <MudText Typo="Typo.caption" Class="mb-4">Dernière mise à jour : juillet 2026</MudText>

        <MudText Typo="Typo.h6" Class="mt-4">Éditeur</MudText>
        <MudText Typo="Typo.body1" Class="mb-2">
            EcoWulf est édité par la communauté « À la bonne heure ! », collectif de joueurs
            bénévoles, à titre non commercial et gratuit.
            Contact : <MudLink Href="https://discord.gg/UeHuqc2dR" Target="_blank">Discord « À la bonne heure ! »</MudLink>
            (contact : f6z2 — « ! Risewulf »).
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4">Directeur de la publication</MudText>
