    private async Task RetrieveData(DataContext? shoppingList = null, bool forceServerReload = false)
    {
        if (ContextService.CurrentUserServer is null || ContextService.CurrentServer is null)
        {
            return;
        }

        if (_isGuidedRunActive)
        {
            ResetGuidedRunState();
        }

        var targetShoppingList = shoppingList ?? ContextService.CurrentUserServer.DataContexts.FirstOrDefault(d => d.IsShoppingList);
        if (targetShoppingList is null)
        {
            _selectedShoppingList = null;
            _referenceDataContext = null;
            TreeItems.Clear();
            return;
        }

        var targetShoppingListId = targetShoppingList.Id;
        _isLoadingData = true;
        StateHasChanged();

        try
        {
            var serverData = ContextService.CurrentServerData;
            if (forceServerReload || serverData is null)
            {
                serverData = await ServerDbService.GetServerWithShoppingListData(ContextService.CurrentServer.Id);
            }

            if (serverData is null)
            {
                _selectedShoppingList = null;
                _referenceDataContext = null;
                TreeItems.Clear();
                return;
            }

            ContextService.CurrentServerData = serverData;
            _selectedShoppingList = await DataContextDbService.GetDataContextWithData(targetShoppingListId, serverData);

            var referenceDataContextId = ContextService.CurrentUserServer.DataContexts
                .FirstOrDefault(d => !d.IsShoppingList && d.IsDefault)?.Id;
            try
            {
                _referenceDataContext = referenceDataContextId is not null
                    ? await DataContextDbService.GetDataContextWithData(referenceDataContextId.Value, serverData)
                    : null;
            }
            catch (Exception)
            {
                _referenceDataContext = null;
            }

            RebuildTree();
        }
        catch (Exception)
        {
            var fallbackShoppingListIds = ContextService.CurrentUserServer.DataContexts
                .Where(d => d.IsShoppingList && d.Id != targetShoppingListId)
                .Select(d => d.Id)
                .ToList();

            _selectedShoppingList = null;
            if (ContextService.CurrentServerData is not null)
            {
                foreach (var fallbackId in fallbackShoppingListIds)
                {
                    try
                    {
                        _selectedShoppingList = await DataContextDbService.GetDataContextWithData(fallbackId, ContextService.CurrentServerData);
                        break;
                    }
                    catch (Exception)
                    {
                        continue;
                    }
                }
            }

            _referenceDataContext = null;
            RebuildTree();
        }
        finally
        {
            _isLoadingData = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ContextService.OnContextChanged -= OnContextChanged;
    }

