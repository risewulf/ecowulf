    private async Task DeleteShoppingList(DataContext shoppingList)
    {
        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", LocalizationService.GetTranslation("ShoppingList.ConfirmDeleteShoppingList", shoppingList.Name));
        if (!confirmed) return;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            DataContextDbService.Destroy(context, shoppingList);
            return Task.CompletedTask;
        });

        ContextService.CurrentUserServer!.DataContexts.Remove(shoppingList);

        if (_selectedShoppingList?.Id == shoppingList.Id)
        {
            await RetrieveData();
        }
    }

