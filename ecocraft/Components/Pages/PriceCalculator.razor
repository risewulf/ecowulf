    private string GetMarginPolicySummary()
    {
        if (ContextService.CurrentServer is null)
        {
            return string.Empty;
        }

        if (IsServerMarginLocked)
        {
            return LocalizationService.GetTranslation(
                "PriceCalculator.Margin.LockedSummary",
                (ContextService.CurrentServer.LockedMargin ?? 0).ToString("0.##"));
        }

        var min = ContextService.CurrentServer.MarginMin;
        var @default = ContextService.CurrentServer.MarginDefault;
        var max = ContextService.CurrentServer.MarginMax;

        if (min is null && @default is null && max is null)
        {
            return string.Empty;
        }

        return LocalizationService.GetTranslation(
            "PriceCalculator.Margin.BoundariesSummary",
            min?.ToString("0.##") ?? "-",
            @default?.ToString("0.##") ?? "-",
            max?.ToString("0.##") ?? "-");
    }

