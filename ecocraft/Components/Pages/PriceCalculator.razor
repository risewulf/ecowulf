    private void RestoreSellGroupsToSnapshot()
    {
        if (_preSellSearchSnapshot is not { } snapshot) return;
        foreach (var row in SellGroupRows)
        {
            if (snapshot.TryGetValue(SellGroupKey(row), out var was) && row.Expanded != was)
            {
                SetSellGroupExpanded(row, was);
            }
        }
    }

    private static string OddIndexRowClass(int index) => index % 2 == 1 ? "row-odd" : "";

    private Element? GetBestRelatedElement(ItemOrTag itemOrTag)
    {
        Element? best = null;
        Element? first = null;
        foreach (var element in itemOrTag.Elements)
        {
            if (!element.IsProduct()) continue;
            if (!_userElementsByElementId.TryGetValue(element.Id, out var ue) || ue.IsReintegrated) continue;
            if (_hideBlueprints && element.Recipe.IsBlueprint) continue;
            first ??= element;
            if (element.Index == 0) { best = element; break; }
        }
        return best ?? first;
    }

    private List<UserElement> GetRelatedProductUserElements(ItemOrTag itemOrTag)
    {
        if (_selectedDataContext is null)
        {
            return [];
        }

        return itemOrTag.Elements
            .Where(element => element.IsProduct())
            .Select(element => element.GetCurrentUserElement(_selectedDataContext))
            .Where(userElement => userElement?.Element?.Recipe is not null
                                  && !userElement.IsReintegrated
                                  && (!_hideBlueprints || !userElement.Element.Recipe.IsBlueprint))
            .Cast<UserElement>()
            .ToList();
    }

    private string GetSellRowClass(ItemOrTag item, int index)
    {
        var classes = new List<string>();
        if (_sellRowBucketIndices.TryGetValue(item.Id, out var bucket) && bucket % 2 == 1)
        {
            classes.Add("row-odd");
        }

        var element = GetBestRelatedElement(item);
        var family = element?.Recipe.FamilyName ?? "";
        if (!string.IsNullOrEmpty(family))
        {
            var skill = element?.Recipe.Skill;

            bool SameFamilyAt(int otherIndex)
            {
                if (otherIndex < 0 || otherIndex >= _itemsToSellDisplay.Count) return false;
                var otherEl = GetBestRelatedElement(_itemsToSellDisplay[otherIndex]);
                return otherEl?.Recipe.Skill == skill && (otherEl?.Recipe.FamilyName ?? "") == family;
            }

            var prevSame = SameFamilyAt(index - 1);
            var nextSame = SameFamilyAt(index + 1);
            if (prevSame || nextSame)
            {
                classes.Add("sell-row-family-member");
                if (!prevSame) classes.Add("sell-row-family-top");
                if (!nextSame) classes.Add("sell-row-family-bottom");
            }
        }

        return string.Join(" ", classes);
    }

    private string SearchItemToSell
    {
        get => _searchItemToSell;
        set
        {
            if (_searchItemToSell == value) return;
            var wasActive = !string.IsNullOrEmpty(_searchItemToSell);
            _searchItemToSell = value ?? "";
            if (!wasActive && !string.IsNullOrEmpty(_searchItemToSell))
            {
                _preSellSearchSnapshot = SellGroupRows.ToDictionary(SellGroupKey, gr => gr.Expanded);
            }
            ApplySellSearchExpansion();
            _sellSearchPending = true;
        }
    }

    private void ApplySellSearchExpansion()
    {
        var isActive = !string.IsNullOrEmpty(_searchItemToSell);
        if (isActive && _itemsToSellDisplay.Count(FilterItemToSell) < SellSearchExpandAllThreshold)
        {
            _itemsToSellTableRef?.ExpandAllGroups();
        }
        else
        {
            _itemsToSellTableRef?.CollapseAllGroups();
            RestoreSellGroupsToSnapshot();
        }
    }

