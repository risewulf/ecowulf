                                                                <MudText Typo="Typo.body2" Class="pt-1">
                                                                    [@relatedUserElements.Count]
                                                                </MudText>
                                                            }
                                                        </MudStack>
                                                    </MudLink>
                                                </MudTooltip>
                                            </MudStack>
