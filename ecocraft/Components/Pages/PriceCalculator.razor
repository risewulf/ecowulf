    private string GetMarginPolicyIndicatorTooltip(UserMargin userMargin)
    {
        if (IsServerMarginLocked)
        {
            var summary = GetMarginPolicySummary();
            return string.IsNullOrWhiteSpace(summary)
                ? LocalizationService.GetTranslation("PriceCalculator.Margin.LockedTooltip")
                : summary;
        }

        if (IsMarginAtMin(userMargin))
        {
            return LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMinPrice");
        }

        if (IsMarginAtMax(userMargin))
        {
            return LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMaxPrice");
