                                                                     Style="width: 111px;"
                                                                     Disabled="@(context.IsTag || isAutoCalculatedPrice)"
                                                                     HideSpinButtons="@(context.IsTag || isAutoCalculatedPrice)"
                                                                     Value="contextUserPrice.Price"
                                                                     Immediate="true"
                                                                     DebounceInterval="@GetAdaptiveInputDebounceMs()"
                                                                     Format="0.##"
                                                                     Variant="Variant.Outlined"
                                                                     Converter="@CultureInvariantConverter.DotOrCommaDecimalNull"
                                                                     Min="context.MinPrice"
                                                                     Max="context.MaxPrice"
                                                                     Adornment="@(isAutoCalculatedPrice || contextUserPrice.Price is null ? Adornment.End : Adornment.None)"
                                                                     AdornmentIcon="@(context.IsTag || isAutoCalculatedPrice ? MDIIcons.Filled.Calculator : MDIIcons.Outline.Information)"
                                                                     AdornmentColor="@(context.IsTag || isAutoCalculatedPrice ? Color.Default : Color.Warning)"
                                                                     ValueChanged="@(value => UpdatePriceCalculation(contextUserPrice, value))"/>
                                                </MudTooltip>
                                                @if (!context.IsTag && !isAutoCalculatedPrice && contextUserPrice.Price is not null)
                                                {
                                                    <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                                                   tabindex="-1"
                                                                   OnClick="() => CopyToClipboard(contextUserPrice.Price)"
                                                                   Size="Size.Small"/>
                                                }
                                            }
                                        </MudStack>
                                    </MudTd>

                                    <MudTd Style="width: 0; padding: 0;"
                                           Class="@($"{(context.AssociatedItems.Any() && _showDetailedTags ? "border-b-0" : "")} {(contextUserPrice.OverrideIsBought ? "border-l-1" : "")}")">
                                        @if (contextUserPrice.OverrideIsBought)
                                        {
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.CancelOverride")">
                                                <MudIconButton Icon="@MDIIcons.Filled.ChevronDoubleRight"
                                                               tabindex="-1"
                                                               OnClick="() => OverridePrice(false, contextUserPrice)"
                                                               Size="Size.Small"/>
                                            </MudTooltip>
                                        }
                                    </MudTd>
                                </RowTemplate>
                                <ChildRowContent>
                                    @if (_showDetailedTags)
                                    {
                                        var detailedAssociatedItems = context.AssociatedItems
                                            .Where(item => item.GetCurrentUserPrice(_selectedDataContext) is not null)
                                            .ToList();

                                        @foreach (var item in detailedAssociatedItems)
                                        {
                                            var contextUserPrice = context.GetCurrentUserPrice(_selectedDataContext);
                                            var itemUserPrice = item.GetCurrentUserPrice(_selectedDataContext);
                                            if (contextUserPrice is null || itemUserPrice is null)
                                            {
                                                continue;
                                            }

                                            <MudTr>
                                                <MudTd Class="@($"pt-0 pb-1 {(detailedAssociatedItems.Last() == item ? "" : "border-b-0")}")">
                                                    <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                                        <MudIcon Icon="@MDIIcons.Filled.ArrowRightBottom"
                                                                 Size="Size.Small"/>
                                                        <EcoIcon Item="item" Size="24"/>
                                                        <MudLink Color="Color.Default" OnClick="@(() => ShowItemOrTagDialog(item))">
                                                            <MudText Typo="Typo.body2" Class="pt-1 ">@LocalizationService.GetTranslation(item)</MudText>
                                                        </MudLink>
                                                    </MudStack>
                                                </MudTd>

                                                <MudTd Class="@($"pt-0 pb-1 {(detailedAssociatedItems.Last() == item ? "" : "border-b-0")}")">
                                                    <MudStack Row Style="position: relative;" Spacing="0">
                                                        @{
                                                            var isAutoCalculatedPrice = _autoCalculatedSellItemIds.Contains(item.Id) && !itemUserPrice.OverrideIsBought;
                                                            var isEmptyPrice = !isAutoCalculatedPrice && itemUserPrice.Price is null;
                                                            var isMinPrice = itemUserPrice.Price == item.MinPrice && itemUserPrice.Price is not null;
                                                            var isMaxPrice = itemUserPrice.Price == item.MaxPrice && itemUserPrice.Price is not null;

                                                            <MudTooltip Text="@(contextUserPrice.PrimaryUserPrice == itemUserPrice ? LocalizationService.GetTranslation("PriceCalculator.CancelFavoriteItem") : LocalizationService.GetTranslation("PriceCalculator.AddFavoriteItem"))">
                                                                <MudIconButton tabindex="-1"
                                                                               Class="onboarding-primary-buy"
                                                                               Color="Color.Primary"
                                                                               Icon="@(contextUserPrice.PrimaryUserPrice == itemUserPrice ? Icons.Material.Filled.Star : Icons.Material.Filled.StarOutline)"
                                                                               Size="Size.Small"
                                                                               OnClick="@(() => SetPrimaryUserPrice(contextUserPrice, itemUserPrice))"/>
                                                            </MudTooltip>
                                                            <MudTooltip Disabled="@(!(isAutoCalculatedPrice || isEmptyPrice || isMinPrice || isMaxPrice))"
                                                                        Text="@(isAutoCalculatedPrice
                                                                                  ? LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isAutoCalculatedPrice")
                                                                                  : isEmptyPrice
                                                                                      ? LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isItemEmptyPrice")
                                                                                      : isMinPrice
                                                                                          ? LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMinPrice")
                                                                                          : LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMaxPrice"))">
                                                                <MudNumericField T="decimal?"
                                                                                 Class="@($"rectangle-input small-adornment {(isAutoCalculatedPrice ? "" : "small-adornment-with-spin")} {(isMinPrice ? "min-price" : isMaxPrice ? "max-price" : "")}")"
                                                                                 Style="width: 85px;"
                                                                                 HideSpinButtons="@isAutoCalculatedPrice"
                                                                                 Format="0.##"
                                                                                 Disabled="@isAutoCalculatedPrice"
                                                                                 Value="itemUserPrice.Price"
                                                                                 Immediate="true"
                                                                                 DebounceInterval="@GetAdaptiveInputDebounceMs()"
                                                                                 Min="item.MinPrice"
                                                                                 Max="item.MaxPrice"
                                                                                 Converter="@CultureInvariantConverter.DotOrCommaDecimalNull"
                                                                                 ValueChanged="@(value => UpdatePriceCalculation(itemUserPrice, value))"
                                                                                 Adornment="@(isAutoCalculatedPrice || itemUserPrice.Price is null ? Adornment.End : Adornment.None)"
                                                                                 AdornmentIcon="@(isAutoCalculatedPrice ? MDIIcons.Filled.Calculator : MDIIcons.Outline.Information)"
                                                                                 AdornmentColor="@(isAutoCalculatedPrice ? Color.Default : Color.Warning)"
                                                                                 Variant="Variant.Outlined"/>
                                                            </MudTooltip>
                                                            @if (!isAutoCalculatedPrice && itemUserPrice.Price is not null)
                                                            {
                                                                <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy"
                                                                               tabindex="-1"
                                                                               OnClick="() => CopyToClipboard(itemUserPrice.Price)"
                                                                               Size="Size.Small"/>
                                                            }
                                                        }
                                                    </MudStack>
                                                </MudTd>

                                                <MudTd Class="@($"pa-0 {(itemUserPrice.OverrideIsBought ? "border-l-1" : "")} {(detailedAssociatedItems.Last() == item ? "" : "border-b-0")}")">
                                                    @if (itemUserPrice.OverrideIsBought)
                                                    {
                                                        <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.CancelOverride")">
                                                            <MudIconButton Icon="@MDIIcons.Filled.ChevronDoubleRight"
                                                                           tabindex="-1"
                                                                           OnClick="() => OverridePrice(false, itemUserPrice)"
                                                                           Size="Size.Small"/>
                                                        </MudTooltip>
                                                    }
                                                </MudTd>
                                            </MudTr>
                                        }
                                    }
                                </ChildRowContent>
                            </MudTable>
                                    </ChildContent>
                                </MudExpansionPanel>
                                <FuelUserPriceTable FuelItems="@_fuelItemsDisplay"
                                                    AssociatedItemsByGroupTagId="@_fuelAssociatedItemsByGroupTagId"
