    private bool ShouldShowCalorieCostPolicyIndicator()
    {
        return IsServerCalorieCostLocked || IsCalorieCostAtMin() || IsCalorieCostAtMax();
    }

    private string GetCalorieCostPolicyIndicatorTooltip()
    {
        if (IsServerCalorieCostLocked)
        {
            var summary = GetCalorieCostPolicySummary();
            return string.IsNullOrWhiteSpace(summary)
                ? LocalizationService.GetTranslation("PriceCalculator.CalorieCost.LockedTooltip")
                : summary;
        }

        if (IsCalorieCostAtMin())
        {
            return LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMinPrice");
        }

        if (IsCalorieCostAtMax())
        {
            return LocalizationService.GetTranslation("PriceCalculator.PriceTooltip.isMaxPrice");
        }

        return string.Empty;
    }

    private string GetCalorieCostPolicyIndicatorIcon()
    {
        return IsServerCalorieCostLocked ? Icons.Material.Filled.Lock : MDIIcons.Outline.Information;
    }

    private string GetCalorieCostPolicySummary()
    {
        if (ContextService.CurrentServer is null)
        {
            return string.Empty;
        }

        if (IsServerCalorieCostLocked)
        {
            return LocalizationService.GetTranslation(
                "PriceCalculator.CalorieCost.LockedSummary",
                (ContextService.CurrentServer.LockedCalorieCost ?? 0).ToString("0.##"));
        }

        var min = ContextService.CurrentServer.CalorieCostMin;
        var @default = ContextService.CurrentServer.CalorieCostDefault;
        var max = ContextService.CurrentServer.CalorieCostMax;

        if (min is null && @default is null && max is null)
        {
            return string.Empty;
        }

        return LocalizationService.GetTranslation(
            "PriceCalculator.CalorieCost.BoundariesSummary",
            min?.ToString("0.##") ?? "-",
            @default?.ToString("0.##") ?? "-",
            max?.ToString("0.##") ?? "-");
    }

    private string GetCalorieCostInputClass()
    {
        var isMinPrice = IsCalorieCostAtMin();
        var isMaxPrice = IsCalorieCostAtMax();

        return $"rectangle-input small-adornment {(IsServerCalorieCostLocked ? "" : "small-adornment-with-spin")} {(isMinPrice ? "min-price" : isMaxPrice ? "max-price" : "")}";
    }

    private bool IsCalorieCostAtMin()
    {
        if (_selectedDataContext is null || IsServerCalorieCostLocked || ContextService.CurrentServer?.CalorieCostMin is not decimal min)
        {
            return false;
        }

        return _selectedDataContext.UserSettings.First().CalorieCost == min;
    }

    private bool IsCalorieCostAtMax()
    {
        if (_selectedDataContext is null || IsServerCalorieCostLocked || ContextService.CurrentServer?.CalorieCostMax is not decimal max)
        {
            return false;
        }

        return _selectedDataContext.UserSettings.First().CalorieCost == max;
    }

    private decimal GetCalorieCostInputMin()
    {
        if (IsServerCalorieCostLocked)
        {
            return decimal.MinValue;
        }

        return ContextService.CurrentServer?.CalorieCostMin ?? decimal.MinValue;
    }

    private decimal GetCalorieCostInputMax()
    {
        if (IsServerCalorieCostLocked)
        {
            return decimal.MaxValue;
        }

        return ContextService.CurrentServer?.CalorieCostMax ?? decimal.MaxValue;
    }

    private decimal ApplyCalorieCostBounds(decimal calorieCost, out bool wasAdjusted)
    {
        wasAdjusted = false;

        var min = ContextService.CurrentServer?.CalorieCostMin;
        var max = ContextService.CurrentServer?.CalorieCostMax;
        var adjustedValue = calorieCost;

        if (min is not null && adjustedValue < min.Value)
        {
            adjustedValue = min.Value;
            wasAdjusted = true;
        }

        if (max is not null && adjustedValue > max.Value)
        {
            adjustedValue = max.Value;
            wasAdjusted = true;
        }

        return adjustedValue;
    }

    private async Task EnforceServerCaloriePolicyIfNeeded()
    {
        if (_selectedDataContext is null || ContextService.CurrentServer is null)
        {
            return;
        }

        var userSetting = _selectedDataContext.UserSettings.First();
        if (ContextService.CurrentServer.IsCalorieCostLocked)
        {
            var lockedCalorieCost = ContextService.CurrentServer.LockedCalorieCost ?? 0;
            if (userSetting.CalorieCost == lockedCalorieCost)
            {
                return;
            }

            userSetting.CalorieCost = lockedCalorieCost;
        }
        else
        {
            var boundedCalorieCost = ApplyCalorieCostBounds(userSetting.CalorieCost, out var wasAdjusted);
            if (!wasAdjusted)
            {
                return;
            }

            userSetting.CalorieCost = boundedCalorieCost;
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            UserSettingDbService.UpdateAll(context, userSetting);
            return Task.CompletedTask;
        });
    }

    private bool ShouldShowMarginPolicyIndicator(UserMargin userMargin)
    {
