    protected override void OnInitialized()
    {
        ContextService.OnContextChanged += OnContextChanged;
        ContextService.OnHelpOverlayRequested += ShowHelpOverlay;

        _groupDefinitionToSell = new TableGroupDefinition<ItemOrTag>
        {
            GroupName = "Temporary",
            Indentation = true,
            Expandable = true,
            IsInitiallyExpanded = false,
            Selector = itemOrTag => GetBestRelatedElement(itemOrTag)?.Recipe.Skill
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _konamiRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("konamiCode.register", _konamiRef);

            _showDetailedTags = await LocalStorageService.GetItem("ShowDetailedTags") != "False";
            _showDetailedRecipes = await LocalStorageService.GetItem("ShowDetailedRecipes") != "False";
            _hideBlueprints = await LocalStorageService.GetItem("HideBlueprints") == "True";
            _expandedSkills = await LocalStorageService.GetItem("ExpandedSkills") != "False";
            _expandedCraftingTables = await LocalStorageService.GetItem("ExpandedCraftingTables") != "False";
            _expandedItemsToBuy = await LocalStorageService.GetItem("ExpandedItemsToBuy") != "False";
            _expandedFuels = await LocalStorageService.GetItem("ExpandedFuels") != "False";
            _expandedItemsToSell = await LocalStorageService.GetItem("ExpandedItemsToSell") != "False";
            _expandedMargins = await LocalStorageService.GetItem("ExpandedMargins") != "False";
            _expandedOptions = await LocalStorageService.GetItem("ExpandedOptions") != "False";
            _showMarginNames = await LocalStorageService.GetItem("ShowMarginNames") == "True";

            var lastDataContextId = await LocalStorageService.GetItem("DataContextId");
            _selectedDataContext = string.IsNullOrEmpty(lastDataContextId)
                ? null
                : ContextService.CurrentUserServer!.DataContexts.FirstOrDefault(dc => dc.Id == new Guid(lastDataContextId));

            await RetrieveData(_selectedDataContext);

            StateHasChanged();
            return;
        }

        if (_expandFirstSellGroupsOnNextRender && SellGroupRows.Any())
        {
            _expandFirstSellGroupsOnNextRender = false;
            foreach (var row in SellGroupRows.Take(3)) SetSellGroupExpanded(row, true);
            StateHasChanged();
        }

        if (_sellSearchPending)
        {
            _sellSearchPending = false;
            ApplySellSearchExpansion();
            if (string.IsNullOrEmpty(_searchItemToSell)) _preSellSearchSnapshot = null;
            StateHasChanged();
        }
    }

    private async Task RetrieveData(DataContext? dataContext = null, bool forceServerReload = false)
    {
        _isLoadingData = true;
        StateHasChanged();

        _selectedDataContext = dataContext ?? ContextService.CurrentUserServer!.DataContexts.First(d => d.IsDefault);

        await LocalStorageService.AddItem("DataContextId", _selectedDataContext.Id.ToString());
        _calculationMode = await GetStoredCalculationModeAsync(_selectedDataContext.Id);

        if (forceServerReload || ContextService.CurrentServerData is null)
        {
            ContextService.CurrentServerData = await ServerDbService.GetServerWithData(ContextService.CurrentServer!.Id);
        }

        SyncCurrentServerCaloriePolicyFromServerData();
        SyncCurrentServerMarginPolicyFromServerData();

        _selectedDataContext = await DataContextDbService.GetDataContextWithData(_selectedDataContext.Id, ContextService.CurrentServerData!);

        await EnsureCraftingTableFuelUserPricesIfNeeded();
        await EnforceServerCaloriePolicyIfNeeded();
        await EnforceServerMarginPolicyIfNeeded();

        await RequestCalculate(CalculateTriggerOrigin.InitialLoad, force: true);

        // Expose le DataContext courant au Header (bouton d'aide d'onboarding) et force le panneau Skills
        // ouvert tant qu'aucun métier n'est ajouté, afin que la flèche pointe un champ visible.
        ContextService.CurrentDataContext = _selectedDataContext;
        ContextService.NotifyCurrentDataContextChanged();
        if (SelectedSkillCount == 0)
        {
            _expandedSkills = true;
        }

        _isLoadingData = false;
        _expandFirstSellGroupsOnNextRender = true;
        StateHasChanged();
    }

    private void SyncCurrentServerCaloriePolicyFromServerData()
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentServerData is null)
        {
            return;
        }

        ContextService.CurrentServer.IsCalorieCostLocked = ContextService.CurrentServerData.IsCalorieCostLocked;
        ContextService.CurrentServer.LockedCalorieCost = ContextService.CurrentServerData.LockedCalorieCost;
        ContextService.CurrentServer.CalorieCostMin = ContextService.CurrentServerData.CalorieCostMin;
        ContextService.CurrentServer.CalorieCostDefault = ContextService.CurrentServerData.CalorieCostDefault;
        ContextService.CurrentServer.CalorieCostMax = ContextService.CurrentServerData.CalorieCostMax;
    }

    private void SyncCurrentServerMarginPolicyFromServerData()
    {
        if (ContextService.CurrentServer is null || ContextService.CurrentServerData is null)
        {
            return;
        }

        ContextService.CurrentServer.IsMarginLocked = ContextService.CurrentServerData.IsMarginLocked;
        ContextService.CurrentServer.LockedMargin = ContextService.CurrentServerData.LockedMargin;
        ContextService.CurrentServer.MarginMin = ContextService.CurrentServerData.MarginMin;
        ContextService.CurrentServer.MarginDefault = ContextService.CurrentServerData.MarginDefault;
        ContextService.CurrentServer.MarginMax = ContextService.CurrentServerData.MarginMax;
    }


    private string GetCalorieCostTooltip()
    {
        if (IsServerCalorieCostLocked)
        {
            return LocalizationService.GetTranslation("PriceCalculator.CalorieCost.LockedTooltip");
        }

        return LocalizationService.GetTranslation("PriceCalculator.CalorieCost.Tooltip");
