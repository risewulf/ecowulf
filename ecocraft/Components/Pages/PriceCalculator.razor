                        <MudStack Row>
                            <MudButton Variant="Variant.Filled" StartIcon="@MDIIcons.Filled.MagicStaff" Color="Color.Tertiary" OnClick="@(() => MagickFix())">@LocalizationService.GetTranslation("PriceCalculator.MagickFix")</MudButton>
