                                                                     FullWidth="false"
                                                                     Class="@($"mt-0 small-adornment flex-no-grow rectangle-input {(isCostMinPrice ? "min-price" : isCostMaxPrice ? "max-price" : "")}")"
                                                                     Style="width: 101px;"
                                                                     HideSpinButtons="true"
                                                                     Format="0.##"
                                                                     Disabled="true"
