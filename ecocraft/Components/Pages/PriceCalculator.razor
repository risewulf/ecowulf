    private async Task IncreasePluginModule(UserCraftingTable userCraftingTable, List<PluginModule> pluginModules)
    {
        var currentIndex = pluginModules.FindIndex(pm => pm.Id == userCraftingTable.PluginModuleId);

        if (currentIndex == pluginModules.Count - 1)
        {
            return;
        }

        userCraftingTable.PluginModule = pluginModules[currentIndex + 1];
        userCraftingTable.PluginModuleId = userCraftingTable.PluginModule.Id;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context => { await UserCraftingTableDbService.UpdateAllAsync(context, userCraftingTable); });

        await RequestCalculate(CalculateTriggerOrigin.PluginModuleChange);
    }

    private async Task DecreasePluginModule(UserCraftingTable userCraftingTable, List<PluginModule> pluginModules)
    {
        var currentIndex = pluginModules.FindIndex(pm => pm.Id == userCraftingTable.PluginModuleId);

        switch (currentIndex)
        {
            case -1:
                return;
            case 0:
                userCraftingTable.PluginModule = null;
                userCraftingTable.PluginModuleId = null;
                break;
            default:
                userCraftingTable.PluginModule = pluginModules[currentIndex - 1];
                userCraftingTable.PluginModuleId = userCraftingTable.PluginModule.Id;
                break;
        }

        userCraftingTable.SkilledPluginModules.Clear();

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context => { await UserCraftingTableDbService.UpdateAllAsync(context, userCraftingTable); });

        await RequestCalculate(CalculateTriggerOrigin.PluginModuleChange);
    }

    private async Task ToggleSkilledPluginModule(UserCraftingTable userCraftingTable, PluginModule pluginModule)
    {
        var existingPluginModule = userCraftingTable.SkilledPluginModules.FirstOrDefault(pm => pm.Id == pluginModule.Id);

        if (existingPluginModule is not null)
        {
            userCraftingTable.SkilledPluginModules.Remove(existingPluginModule);
        }
        else
        {
            userCraftingTable.SkilledPluginModules.Add(pluginModule);
        }

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, async context => { await UserCraftingTableDbService.UpdateAllAsync(context, userCraftingTable); });

        await RequestCalculate(CalculateTriggerOrigin.StructureChange);
    }

    private bool FilterTagToBuy(ItemOrTag itemOrTag)
    {
        return FilterItemToBuy(itemOrTag, _searchTagToBuy, _selectedTagToBuy);
    }

    private bool FilterItemToSell(ItemOrTag itemOrTag)
    {
        return FilterSellItemOrRecipe(itemOrTag, _searchItemToSell, _selectedItemToSell);
    }

    private bool FilterItemToBuy(ItemOrTag itemOrTag, string search, ItemOrTag? specificTag = null)
    {
        if (!MatchesSpecificTag(itemOrTag, specificTag))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(search))
        {
            return true;
        }

        if (MatchesItemOrTag(itemOrTag, search))
        {
            return true;
        }

        if (itemOrTag.GetCurrentUserPrice(_selectedDataContext!)?.PrimaryUserPrice?.ItemOrTag is { } primaryItemOrTag
            && MatchesItemOrTag(primaryItemOrTag, search))
        {
            return true;
        }

        return itemOrTag.AssociatedItems
            .Where(item => item.GetCurrentUserPrice(_selectedDataContext!) is not null)
            .Any(item => MatchesItemOrTag(item, search));
    }

    private bool FilterSellItemOrRecipe(ItemOrTag itemOrTag, string search, ItemOrTag? specificTag = null)
    {
        if (!MatchesSpecificTag(itemOrTag, specificTag))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(search))
        {
            return true;
        }

        if (MatchesItemOrTag(itemOrTag, search))
        {
            return true;
        }

        return GetRelatedProductUserElements(itemOrTag)
            .Any(userElement => MatchesRecipe(userElement.Element.Recipe, search));
    }

    private bool MatchesSpecificTag(ItemOrTag itemOrTag, ItemOrTag? specificTag)
    {
        return specificTag is null || itemOrTag.AssociatedTags.Contains(specificTag);
    }

    private bool MatchesItemOrTag(ItemOrTag itemOrTag, string search)
    {
        return itemOrTag.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
               || LocalizationService.GetTranslation(itemOrTag).Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesRecipe(Recipe recipe, string search)
    {
        if (recipe.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
            || recipe.FamilyName.Contains(search, StringComparison.OrdinalIgnoreCase)
            || LocalizationService.GetTranslation(recipe).Contains(search, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return recipe.Skill is not null
               && (recipe.Skill.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                   || LocalizationService.GetTranslation(recipe.Skill).Contains(search, StringComparison.OrdinalIgnoreCase));
    }

