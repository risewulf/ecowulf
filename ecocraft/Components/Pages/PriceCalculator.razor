@page "/"
@implements IDisposable
@using ecocraft.Components.Dialog
@using ecocraft.Extensions
@using ecocraft.Models
@using ecocraft.Services
@using ecocraft.Services.DbServices
@using System.Globalization;
@using System.Reflection;
@using ecocraft.Components.Utils
@using Microsoft.EntityFrameworkCore
@inject IDialogService DialogService
@inject ContextService ContextService
@inject LocalStorageService LocalStorageService
@inject ServerDbService ServerDbService
@inject UserServerDataService UserServerDataService
@inject UserSettingDbService UserSettingDbService
@inject UserPriceDbService UserPriceDbService
@inject UserSkillDbService UserSkillDbService
@inject UserTalentDbService UserTalentDbService
@inject UserCraftingTableDbService UserCraftingTableDbService
@inject UserMarginDbService UserMarginDbService
@inject PriceCalculatorService PriceCalculatorService
@inject CraftingTableFuelCostService CraftingTableFuelCostService
@inject LocalizationService LocalizationService
@inject DataContextDbService DataContextDbService
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation
@inject IDbContextFactory<EcoCraftDbContext> EcoCraftDbFactory

<PageTitle>@LocalizationService.GetTranslation("PriceCalculator.PageTitle") - EcoWulf</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-0">
    <MudGrid Style="height: auto">
        <MudItem xs="12" Class="px-4 pt-4">
            <MudStack Row Spacing="3">
                @foreach (var dataContext in ContextService.CurrentUserServer!.DataContexts.Where(d => !d.IsShoppingList))
                {
                    <ContextChip @key="dataContext.Id"
                                 DataContext="dataContext"
                                 IsSelected="_selectedDataContext?.Id == dataContext.Id"
                                 CanDelete="!dataContext.IsDefault"
                                 CanRename="true"
                                 CanDuplicate="true"
                                 CanSetDefault="!dataContext.IsDefault"
                                 StartInRenameMode="@(_pendingRenameContextId == dataContext.Id)"
                                 OnSelect="@(() => SelectDataContext(dataContext))"
                                 OnRename="@(newName => RenameDataContext(dataContext, newName))"
                                 OnDuplicate="@(() => DuplicateDataContext(dataContext))"
                                 OnSetDefault="@(() => SetDefaultDataContextHandler(dataContext))"
                                 OnDelete="@(() => DeleteDataContext(dataContext))" />
                }
                <MudButton Color="Color.Tertiary"
                           EndIcon="@MDIIcons.Filled.Plus"
                           Variant="Variant.Outlined"
                           OnClick="@(() => AddDataContext())">
                    @LocalizationService.GetTranslation("PriceCalculator.AddDataContext")
                </MudButton>
                <MudSpacer/>
                @if (ShouldShowStatusIndicator)
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Style="min-width: 150px; justify-content: flex-end;">
                        @if (_isLoadingData || IsCalculationInProgress)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true"/>
                        }
                        else if (HasPendingManualCalculation)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning"/>
                        }
                        <MudText Typo="Typo.body2">@GetStatusLabel()</MudText>
                    </MudStack>
                }
                @if (IsManualCalculationMode)
                {
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(_selectedDataContext is null || IsCalculationInProgress)"
                               OnClick="@(async () => await RequestCalculate(CalculateTriggerOrigin.ManualButton, force: true, bypassDebounce: true))">
                        @LocalizationService.GetTranslation("PriceCalculator.CalculationMode.CalculateNow")
                    </MudButton>
                }
            </MudStack>
        </MudItem>

        @if (!_isLoadingData && _selectedDataContext is not null && ContextService.CurrentServerData is not null)
        {
            <ErrorBoundary>
                <ChildContent>
                    @{
                        if (_calculationError is not null)
                        {
                            throw _calculationError;
                        }
                    }
                    <MudItem md="12" lg="3" Class="pa-2 d-flex flex-column">
                        <MudPaper Style="background-color: var(--mud-palette-background)" Elevation="0" Class="flex-grow-1 pa-2">
                            @* Composant 1 — encart d'orientation tant qu'aucun métier n'est ajouté ; se résout tout seul à l'ajout du premier métier. *@
                            @if (SelectedSkillCount == 0)
                            {
                                <div class="onboarding-step-wrapper">
                                    <div class="onboarding-step-card onboarding-step-card--active">
                                        <div class="onboarding-step-badge">1</div>
                                        <div class="onboarding-step-body">
                                            <div class="onboarding-step-title">@LocalizationService.GetTranslation("Onboarding.Steps.Skills.Title")</div>
                                            <div class="onboarding-step-desc">@LocalizationService.GetTranslation("Onboarding.Steps.Skills.Desc")</div>
                                        </div>
                                    </div>
                                    <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Class="onboarding-arrow" Color="Color.Primary"/>
                                </div>
                            }
                            <MudExpansionPanels MultiExpansion="true">

                                <MudExpansionPanel Text="@($"{LocalizationService.GetTranslation("PriceCalculator.Skills")} ({_selectedDataContext.UserSkills.Where(us => us.Skill is not null).ToList().Count})")" @bind-Expanded="ExpandedSkills">
                                    <MudAutocomplete T="Skill"
                                                     @ref="_skillAutocompleteRef"
                                                     Value="_emptySkill"
                                                     Disabled="@(UserServerDataService.GetAvailableSkills(_selectedDataContext, ContextService.CurrentServerData!).Count == 0)"
                                                     SearchFunc="SearchSkills"
                                                     ValueChanged="AddUserSkill"
                                                     CoerceText="false"
                                                     Placeholder="@LocalizationService.GetTranslation("PriceCalculator.AddSkill")"
                                                     Dense="true"
                                                     Class="auto-complete-input"
                                                     MaxItems="null"
                                                     Variant="Variant.Outlined"
                                                     AnchorOrigin="Origin.BottomLeft"
                                                     TransformOrigin="Origin.TopLeft">
                                        <ItemTemplate>
                                            <MudStack Class="pl-2" Spacing="0">
                                                @if (!string.IsNullOrEmpty(context.Profession) && _previousProfession != context.Profession)
                                                {
                                                    <MudText Color="Color.Primary" Typo="Typo.caption">@GetProfessionLabel(context)</MudText>
                                                }
                                                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                                    <EcoIcon Item="@context" Size="24"/>
                                                    <MudText>@LocalizationService.GetTranslation(context)</MudText>
                                                </MudStack>
                                                @{
                                                    _previousProfession = context.Profession;
                                                }
                                            </MudStack>
                                        </ItemTemplate>
                                    </MudAutocomplete>

                                    <MudTable Items="_selectedDataContext.UserSkills.Where(us => us.Skill is not null)"
                                              Hover="true"
                                              Dense="true"
                                              Class="mt-4"
                                              RowClassFunc="(_, i) => OddIndexRowClass(i)">
                                        <HeaderContent>
                                            <MudTh Class="pl-2">@LocalizationService.GetTranslation("Name")</MudTh>
                                            <MudTh Class="pl-1">@LocalizationService.GetTranslation("Level")</MudTh>
                                            <MudTh Class="pl-1">@LocalizationService.GetTranslation("Talents")</MudTh>
                                            <MudTh></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd Class="pa-1">
                                                <MudLink Color="Color.Default" OnClick="@(() => ShowSkillDialog(context.Skill))">
                                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexStart">
                                                        <EcoIcon Item="@context.Skill"/>
                                                        <MudText Typo="Typo.body2">@LocalizationService.GetTranslation(context.Skill)</MudText>
                                                    </MudStack>
                                                </MudLink>
                                            </MudTd>
                                            <MudTd Class="px-0">
                                                <MudNumericField T="int"
                                                                 Value="@context.Level"
                                                                 Class="square-input flex-no-grow"
                                                                 Format="0"
                                                                 Step="1"
                                                                 Culture="CultureInfo.InvariantCulture"
                                                                 Min="1"
                                                                 Max="@context.Skill!.MaxLevel"
                                                                 Variant="Variant.Outlined"
                                                                 Immediate="true"
                                                                 ValueChanged="(int newValue) => OnLevelChanged(context, newValue)"/>
                                            </MudTd>
                                            <MudTd Class="px-0">
                                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Spacing="2">
                                                    @foreach (var talentGroup in context.Skill!.Talents.Where(t => context.Level >= t.Level).OrderBy(t => t.Level).GroupBy(t => t.TalentGroupName))
                                                    {
                                                        var talents = talentGroup.ToList();
                                                        var talent = talents.First();
                                                        var userTalent = talent.GetCurrentUserTalent(_selectedDataContext);
                                                        var currentReduction = userTalent is null ? 0m : talent.GetReductionPercentForLevel(userTalent.Level);
                                                        var showReductionPercent = talent.HasReductionDisplay();
                                                        var description = LocalizationService.GetTranslation(talent.LocalizedDescription);
                                                        var tooltipTitle = showReductionPercent
                                                            ? $"{LocalizationService.GetTranslation(talent)} [{currentReduction.ToString("0.##")}%]"
                                                            : LocalizationService.GetTranslation(talent);

                                                        <MudTooltip Text="@(string.IsNullOrWhiteSpace(description) ? tooltipTitle : $"{tooltipTitle} - {description}")" RootClass="d-flex">
                                                            @if (talent.MaxLevel <= 1)
                                                            {
                                                                <MudLink OnClick="() => ToggleBinaryTalent(talents)" Class="d-flex" Style="align-items: center">
                                                                    <EcoIcon Item="talent" Size="32" Class="@($"{(userTalent is null ? "no-talent" : "has-talent")}")"/>
                                                                </MudLink>
                                                            }
                                                            else
                                                            {
                                                                var isMaxLevelReached = userTalent is not null && userTalent.Level >= talent.MaxLevel;
                                                                var isMinLevelReached = userTalent is null;
                                                                var currentLevel = userTalent?.Level ?? 0;

                                                                <div class="talent-level-control">
                                                                    <div class="talent-icon-wrapper">
                                                                        <MudLink OnClick="() => IncreaseTalentLevel(talents)"
                                                                                 Class="@($"talent-level-action talent-level-action-up {(isMaxLevelReached ? "disabled" : "")}")">
                                                                            +
                                                                        </MudLink>
                                                                        <EcoIcon Item="talent" Size="32" Class="@($"{(userTalent is null ? "no-talent" : "has-talent")}")"/>
                                                                        <MudText Typo="Typo.caption" Class="talent-current-level">@currentLevel</MudText>
                                                                        <MudLink OnClick="() => DecreaseTalentLevel(talents)"
                                                                                 Class="@($"talent-level-action talent-level-action-down {(isMinLevelReached ? "disabled" : "")}")">
                                                                            -
                                                                        </MudLink>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </MudTooltip>
                                                    }
                                                </MudStack>
                                            </MudTd>
                                            <MudTd Class="px-0" Style="text-align: right">
                                                <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                                               aria-label="delete"
                                                               tabindex="-1"
                                                               Size="Size.Small"
                                                               OnClick="@(() => RemoveUserSkill(context))"/>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudExpansionPanel>
                                <MudExpansionPanel id="onboarding-crafting-tables" Text="@($"{LocalizationService.GetTranslation("PriceCalculator.CraftingTables")} ({_selectedDataContext.UserCraftingTables.Count})")" @bind-Expanded="ExpandedCraftingTables">
                                    <MudAutocomplete T="CraftingTable"
                                                     @ref="_craftingTableAutocompleteRef"
                                                     Value="_emptyCraftingTable"
                                                     Disabled="@(UserServerDataService.GetAvailableCraftingTables(_selectedDataContext, ContextService.CurrentServerData!).Count == 0)"
                                                     SearchFunc="SearchCraftingTables"
                                                     ValueChanged="AddUserCraftingTable"
                                                     CoerceText="false"
                                                     Placeholder="@LocalizationService.GetTranslation("PriceCalculator.AddCraftingTable")"
                                                     Dense="true"
                                                     Class="mt-4 auto-complete-input"
                                                     MaxItems="null"
                                                     Variant="Variant.Outlined"
                                                     AnchorOrigin="Origin.BottomLeft"
                                                     TransformOrigin="Origin.TopLeft">
                                        <ItemTemplate>
                                            <MudStack Row Spacing="2" Class="pl-2">
                                                <EcoIcon Item="context" Size="24"></EcoIcon>
                                                <MudText>@LocalizationService.GetTranslation(context)</MudText>
                                            </MudStack>
                                        </ItemTemplate>
                                    </MudAutocomplete>

                                    <MudTable Items="@_selectedDataContext.UserCraftingTables.OrderBy(c => LocalizationService.GetTranslation(c.CraftingTable))"
                                              FixedHeader="true"
                                              Hover="true"
                                              Class="mt-4 mud-table-container-no-overflow-y"
                                              Dense="true"
                                              RowClassFunc="(_, i) => OddIndexRowClass(i)">
                                        <HeaderContent>
                                            <MudTh>@LocalizationService.GetTranslation("Name")</MudTh>
                                            <MudTh Class="pl-1">@LocalizationService.GetTranslation("Upgrade")</MudTh>
                                            <MudTh Class="p-0 pl-1">@LocalizationService.GetTranslation("PriceCalculator.CostMin.CostMin")</MudTh>
                                            <MudTh Class="px-1"></MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd Class="pa-1 crafting-table-config-cell">
                                                <MudLink Color="Color.Default" OnClick="@(() => ShowCraftingTableDialog(context))">
                                                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.FlexStart" Class="crafting-table-config-stack">
                                                        <EcoIcon Item="@context.CraftingTable"/>
                                                        <MudText Typo="Typo.body2">@LocalizationService.GetTranslation(context.CraftingTable)</MudText>
                                                    </MudStack>
                                                </MudLink>
                                            </MudTd>
                                            <MudTd Class="pa-1 crafting-table-config-cell">
                                                <CraftingTablePluginModuleControl UserCraftingTable="context"
                                                                                  Class="crafting-table-config-stack"
                                                                                  IncreaseRequested="@(pluginModules => IncreasePluginModule(context, pluginModules))"
                                                                                  DecreaseRequested="@(pluginModules => DecreasePluginModule(context, pluginModules))"
                                                                                  SkilledPluginModuleToggled="@(pluginModule => ToggleSkilledPluginModule(context, pluginModule))"/>
                                            </MudTd>
                                            <MudTd Class="px-1 crafting-table-config-cell">
                                                <MudTooltip Text="@GetCraftMinuteFeeConfigurationTooltip(context)">
                                                    <MudNumericField T="decimal"
                                                                     Class="rectangle-input small-adornment"
                                                                     Style="width: 80px;"
                                                                     Value="@GetCraftMinuteFeeConfigurationValue(context)"
                                                                     Disabled="true"
                                                                     HideSpinButtons="true"
                                                                     Format="0.##"
                                                                     Converter="@CultureInvariantConverter.DotOrCommaDecimal"
                                                                     Adornment="Adornment.End"
                                                                     AdornmentIcon="@MDIIcons.Filled.Calculator"
                                                                     AdornmentColor="Color.Default"
                                                                     Variant="Variant.Outlined"/>
                                                </MudTooltip>
                                            </MudTd>
                                            <MudTd Class="px-1">
                                                <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                                               aria-label="delete"
                                                               tabindex="-1"
                                                               Size="Size.Small"
                                                               OnClick="@(() => RemoveUserCraftingTable(context))"/>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudExpansionPanel>
                                <MudExpansionPanel id="onboarding-margins" Text="@($"{LocalizationService.GetTranslation("Margins")} ({_selectedDataContext.UserMargins.Count})")" @bind-Expanded="ExpandedMargins">
                                    @if (_selectedDataContext.UserSettings.FirstOrDefault() is not null)
                                    {
                                        <MudTable Items="_selectedDataContext.UserMargins"
                                                  FixedHeader="true"
                                                  Hover="true"
                                                  Class="mt-4"
                                                  Dense="true"
                                                  RowClassFunc="(_, i) => OddIndexRowClass(i)">
                                            <HeaderContent>
                                                <MudTh Class="px-1">
                                                    <MudText>@LocalizationService.GetTranslation("Name")</MudText>
                                                </MudTh>
                                                <MudTh Class="px-1">
                                                    <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.MarginPercent.Tooltip")">
                                                        <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.MarginPercent.MarginPercent")</MudText>
                                                    </MudTooltip>
                                                </MudTh>
                                                <MudTh Class="px-1">
                                                    <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.Rounding.Tooltip")">
                                                        <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.Rounding.Rounding")</MudText>
                                                    </MudTooltip>
                                                </MudTh>
                                                <MudTh Class="px-1"></MudTh>
                                            </HeaderContent>
                                            <RowTemplate>
                                                <MudTd Class="py-1 px-1">
                                                    <MudTextField Value="context.Name"
                                                                  Typo="Typo.body2"
                                                                  Style="border-bottom-color: gray"
                                                                  ValueChanged="@((string v) => UpdateMarginName(context, v))"/>
                                                </MudTd>
                                                <MudTd Class="py-1 px-1">
                                                    <MudTooltip Disabled="@(!ShouldShowMarginPolicyIndicator(context))" Text="@GetMarginPolicyIndicatorTooltip(context)">
                                                        <MudStack Row AlignItems="AlignItems.Center" Spacing="0">
                                                            <MudNumericField T="decimal"
                                                                             Immediate
                                                                             Class="@GetMarginInputClass(context)"
                                                                             Style="width: 93px"
                                                                             Value="@GetDisplayedMarginValue(context)"
                                                                             Disabled="IsServerMarginLocked"
                                                                             HideSpinButtons="IsServerMarginLocked"
                                                                             Min="GetMarginInputMin()"
                                                                             Max="GetMarginInputMax()"
                                                                             Adornment="@(ShouldShowMarginPolicyIndicator(context) ? Adornment.End : Adornment.None)"
                                                                             AdornmentIcon="@GetMarginPolicyIndicatorIcon()"
                                                                             AdornmentColor="@(ShouldShowMarginPolicyIndicator(context) ? Color.Warning : Color.Default)"
                                                                             Converter="@CultureInvariantConverter.DotOrCommaDecimal"
                                                                             ValueChanged="@(v => UpdateMargin(context, v))"
                                                                             Variant="Variant.Outlined"/>
                                                            <MudText Class="ml-1">%</MudText>
                                                        </MudStack>
                                                    </MudTooltip>
                                                </MudTd>
                                                <MudTd Class="py-1 px-1">
                                                    <MudSelect T="RoundingMode"
                                                               Class="select-dense very-dense"
                                                               Style="width: 80px"
                                                               Value="context.Rounding"
                                                               Variant="Variant.Outlined"
                                                               ValueChanged="@(v => UpdateMarginRounding(context, v))">
                                                        <MudSelectItem Value="@RoundingMode.None">@LocalizationService.GetTranslation("PriceCalculator.Rounding.None")</MudSelectItem>
                                                        <MudSelectItem Value="@RoundingMode.Up">@LocalizationService.GetTranslation("PriceCalculator.Rounding.Up")</MudSelectItem>
                                                        <MudSelectItem Value="@RoundingMode.Down">@LocalizationService.GetTranslation("PriceCalculator.Rounding.Down")</MudSelectItem>
                                                        <MudSelectItem Value="@RoundingMode.Marketing">@LocalizationService.GetTranslation("PriceCalculator.Rounding.Marketing")</MudSelectItem>
                                                    </MudSelect>
                                                </MudTd>
                                                <MudTd Class="py-1 px-1" Style="text-align: right;">
                                                    <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.RemoveMargin")" Class="flex">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                                                       tabindex="-1"
                                                                       Size="Size.Small"
                                                                       OnClick="@(() => OnRemoveMargin(context))"/>
                                                    </MudTooltip>
                                                </MudTd>
                                            </RowTemplate>
                                        </MudTable>
                                        <MudStack Row Class="mt-1" Style="width: 100%" Justify="Justify.Center" AlignItems="AlignItems.Center">
                                            <MudButton Class="py-1"
                                                       StartIcon="@Icons.Material.Filled.Add"
                                                       tabindex="-1"
                                                       OnClick="OnAddMargin">
                                                @LocalizationService.GetTranslation("PriceCalculator.AddMargin")
                                            </MudButton>
                                        </MudStack>
                                    }
                                </MudExpansionPanel>

                                <MudExpansionPanel id="onboarding-options" Text="@LocalizationService.GetTranslation("Options")" @bind-Expanded="ExpandedOptions">
                                    <MudStack Spacing="1" Class="pa-2">
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.NonSkilled.Tooltip")">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.NonSkilled.NonSkilled")</MudText>
                                            </MudTooltip>
                                            <MudCheckBox T="bool" Value="_selectedDataContext.UserSettings.First().DisplayNonSkilledRecipes" Variant="Variant.Outlined" ValueChanged="OnOptionDisplayChanged"/>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.HideBlueprints.Tooltip")">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.HideBlueprints.HideBlueprints")</MudText>
                                            </MudTooltip>
                                            <MudCheckBox T="bool" Value="_hideBlueprints" Variant="Variant.Outlined" ValueChanged="OnHideBlueprintsChanged"/>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.LevelAccessible.Tooltip")">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.LevelAccessible.LevelAccessible")</MudText>
                                            </MudTooltip>
                                            <MudCheckBox T="bool" Value="_selectedDataContext.UserSettings.First().OnlyLevelAccessibleRecipes" Variant="Variant.Outlined" ValueChanged="OnOptionOnlyLevelChanged"/>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.ApplyMarginBetweenSkills.Tooltip")">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.ApplyMarginBetweenSkills.ApplyMarginBetweenSkills")</MudText>
                                            </MudTooltip>
                                            <MudCheckBox T="bool" Value="_selectedDataContext.UserSettings.First().ApplyMarginBetweenSkills" Variant="Variant.Outlined" ValueChanged="OnOptionApplyMarginBetweenSkillsChanged"/>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip>
                                                <TooltipContent>
                                                    <MudStack Spacing="0">
                                                        <MudText>@LocalizationService.GetTranslation("PriceCalculator.MarginType.Tooltip.1")</MudText>
                                                        <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("PriceCalculator.MarginType.Tooltip.2")</MudText>
                                                        <MudText Typo="Typo.body2">@LocalizationService.GetTranslation("PriceCalculator.MarginType.Tooltip.3")</MudText>
                                                    </MudStack>
                                                </TooltipContent>
                                                <ChildContent>
                                                    <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.MarginType.MarginType")</MudText>
                                                </ChildContent>
                                            </MudTooltip>
                                            <div class="flex-no-grow">
                                                <MudSelect T="MarginType"
                                                           Class="select-dense very-dense"
                                                           Value="_selectedDataContext.UserSettings.First().MarginType"
                                                           Style="width: 100px"
                                                           Variant="Variant.Outlined"
                                                           ValueChanged="OnOptionMarginTypeChanged">
                                                    <MudSelectItem Value="@MarginType.MarkUp">@LocalizationService.GetTranslation("PriceCalculator.MarginType.MarkUp")</MudSelectItem>
                                                    <MudSelectItem Value="@MarginType.GrossMargin">@LocalizationService.GetTranslation("PriceCalculator.MarginType.GrossMargin")</MudSelectItem>
                                                </MudSelect>
                                            </div>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@LocalizationService.GetTranslation("PriceCalculator.CalculationMode.Tooltip")">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.CalculationMode.Label")</MudText>
                                            </MudTooltip>
                                            <div class="flex-no-grow">
                                                <MudSelect T="CalculationMode"
                                                           Class="select-dense very-dense"
                                                           Value="_calculationMode"
                                                           Style="width: 110px"
                                                           Variant="Variant.Outlined"
                                                           ValueChanged="OnOptionCalculationModeChanged">
                                                    <MudSelectItem Value="@CalculationMode.AutoSmart">@LocalizationService.GetTranslation("PriceCalculator.CalculationMode.AutoSmart")</MudSelectItem>
                                                    <MudSelectItem Value="@CalculationMode.Manual">@LocalizationService.GetTranslation("PriceCalculator.CalculationMode.Manual")</MudSelectItem>
                                                </MudSelect>
                                            </div>
                                        </MudStack>
                                        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudTooltip Text="@GetCalorieCostTooltip()">
                                                <MudText Class="tooltip-text">@LocalizationService.GetTranslation("PriceCalculator.CalorieCost.CalorieCost")</MudText>
                                            </MudTooltip>
                                            <div>
                                                <MudTooltip Disabled="@(!ShouldShowCalorieCostPolicyIndicator())" Text="@GetCalorieCostPolicyIndicatorTooltip()">
                                                    <MudNumericField T="decimal"
                                                                     ValueChanged="UpdateCalorieCost"
                                                                     Class="@GetCalorieCostInputClass()"
                                                                     Value="_selectedDataContext.UserSettings.First().CalorieCost"
                                                                     Disabled="IsServerCalorieCostLocked"
