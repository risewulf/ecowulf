    private int GetAdaptiveInputDebounceMs()
    {
        if (_selectedDataContext is null)
        {
            return 250;
        }

        var configuredProfessions = _selectedDataContext.UserSkills.Count(userSkill => userSkill.Skill is not null);
        var isHeavyContext = configuredProfessions >= 5 && _selectedDataContext.UserRecipes.Count >= 30;
        return isHeavyContext ? 800 : 250;
    }

    private int GetDebounceMsForTrigger(CalculateTriggerOrigin origin, bool bypassDebounce)
    {
        if (bypassDebounce)
        {
            return 0;
        }

        return origin switch
        {
            CalculateTriggerOrigin.SkillChange => SkillChangeCalculationDebounceMs,
            CalculateTriggerOrigin.PriceInput or CalculateTriggerOrigin.MarginInput => GetAdaptiveInputDebounceMs(),
            CalculateTriggerOrigin.PluginModuleChange => GetAdaptiveInputDebounceMs(),
            _ => 0,
        };
    }

    private async Task RequestCalculate(CalculateTriggerOrigin origin, bool force = false, bool bypassDebounce = false)
    {
        if (_selectedDataContext is null)
        {
            return;
        }

        if (!force && IsManualCalculationMode)
        {
            _hasPendingManualCalculation = true;
            _queuedCalculationOrigin = origin;
            RefreshCategorizedDisplayCaches();
            StateHasChanged();
            return;
        }

        var debounceMs = GetDebounceMsForTrigger(origin, bypassDebounce);

        // Skill/recipe/structure changes can remove/relink UserPrices before the calculation executes.
        // Refresh display caches immediately to avoid rendering rows with stale ItemOrTag references.
        if (origin is CalculateTriggerOrigin.SkillChange or CalculateTriggerOrigin.RecipeChange or CalculateTriggerOrigin.StructureChange)
        {
            RefreshCategorizedDisplayCaches();
            StateHasChanged();
        }

        if (debounceMs > 0)
        {
            var currentDebounceCts = new CancellationTokenSource();
            var previousDebounceCts = System.Threading.Interlocked.Exchange(ref _calculateDebounceCts, currentDebounceCts);
            previousDebounceCts?.Cancel();
            previousDebounceCts?.Dispose();

            try
            {
                await Task.Delay(debounceMs, currentDebounceCts.Token);
            }
            catch (TaskCanceledException)
            {
                return;
            }
            finally
            {
                if (ReferenceEquals(_calculateDebounceCts, currentDebounceCts))
                {
                    _calculateDebounceCts = null;
                }

                currentDebounceCts.Dispose();
            }
        }

        lock (_calculationQueueLock)
        {
            if (_calculationLoopRunning)
            {
                _queuedCalculation = true;
                _queuedCalculationOrigin = origin;
                return;
            }

            _calculationLoopRunning = true;
            _queuedCalculation = false;
            _queuedCalculationOrigin = origin;
        }

        try
        {
            var currentOrigin = origin;

            while (true)
            {
                await ExecuteCalculationOnce(currentOrigin);

                lock (_calculationQueueLock)
                {
                    if (!_queuedCalculation)
                    {
                        _calculationLoopRunning = false;
                        break;
                    }

                    _queuedCalculation = false;
                    currentOrigin = _queuedCalculationOrigin;
                }
            }
        }
        finally
        {
            lock (_calculationQueueLock)
            {
                _calculationLoopRunning = false;
            }
        }
    }

    private async Task ExecuteCalculationOnce(CalculateTriggerOrigin origin)
    {
        System.Threading.Interlocked.Increment(ref _activeCalculations);
        StateHasChanged();

        try
        {
            for (var attempt = 0; attempt < 2; attempt++)
            {
                try
                {
                    await EnforceServerCaloriePolicyIfNeeded();
                    await EnforceServerMarginPolicyIfNeeded();

                    await PriceCalculatorService.Calculate(_selectedDataContext!, origin.ToString());

                    RefreshCategorizedDisplayCaches();
                    _hasPendingManualCalculation = false;
                    _calculationError = null;
                    return;
                }
                catch (DbUpdateConcurrencyException) when (attempt == 0)
                {
                    _calculationError = null;
                }
                catch (DbUpdateConcurrencyException)
                {
                    _calculationError = null;
                    return;
                }
                catch (Exception ex)
                {
                    _calculationError = ex;
                    return;
                }
            }
        }
        finally
        {
            System.Threading.Interlocked.Decrement(ref _activeCalculations);
            StateHasChanged();
        }
    }

    private void RefreshCategorizedDisplayCaches()
    {
        if (_selectedDataContext is null)
        {
            _itemsToBuyDisplay = [];
            _fuelItemsDisplay = [];
            _itemsToSellDisplay = [];
            _fuelAssociatedItemsByGroupTagId = [];
            _fuelItemCount = 0;
            _autoCalculatedSellItemIds = [];
            _userElementsByElementId = [];
            _sellRowBucketIndices.Clear();
            return;
        }

        var categorizedForDisplay = PriceCalculatorService.GetCategorizedItemOrTagsForDisplay(_selectedDataContext);
        var fuelAssociatedItemsByGroupTagId = PriceCalculatorService.GetFuelAssociatedItemsByGroupTagIdForDisplay(_selectedDataContext);
        var fuelItemsForDisplay = PriceCalculatorService.GetFuelItemOrTagsForDisplay(_selectedDataContext)
            .Where(itemOrTag => itemOrTag.GetCurrentUserPrice(_selectedDataContext) is not null)
            .ToList();

        var displayedFuelGroupTagIds = fuelItemsForDisplay
            .Where(itemOrTag => itemOrTag.IsTag)
            .Select(itemOrTag => itemOrTag.Id)
            .ToHashSet();

        _fuelAssociatedItemsByGroupTagId = fuelAssociatedItemsByGroupTagId
            .Where(group => displayedFuelGroupTagIds.Contains(group.Key))
            .ToDictionary(
                group => group.Key,
                group => group.Value
                    .Where(itemOrTag => itemOrTag.GetCurrentUserPrice(_selectedDataContext) is not null)
                    .ToList());

        _fuelAssociatedItemsByGroupTagId = _fuelAssociatedItemsByGroupTagId
            .Where(group => group.Value.Count > 0)
            .ToDictionary(group => group.Key, group => group.Value);

        _fuelItemsDisplay = fuelItemsForDisplay
            .Where(itemOrTag => !itemOrTag.IsTag || _fuelAssociatedItemsByGroupTagId.ContainsKey(itemOrTag.Id))
            .ToList();

        _fuelItemCount = _fuelItemsDisplay
            .Where(itemOrTag => !itemOrTag.IsTag)
            .Select(itemOrTag => itemOrTag.Id)
            .Concat(_fuelAssociatedItemsByGroupTagId.Values
                .SelectMany(associatedItems => associatedItems)
                .Select(itemOrTag => itemOrTag.Id))
            .Distinct()
            .Count();

        _itemsToBuyDisplay = categorizedForDisplay.ToBuy
            .Where(itemOrTag => itemOrTag.GetCurrentUserPrice(_selectedDataContext) is not null)
            .ToList();
        _itemsToSellDisplay = categorizedForDisplay.ToSell
            .Where(itemOrTag => itemOrTag.GetCurrentUserPrice(_selectedDataContext) is not null)
            .ToList();

        var categorizedForAutoSell = PriceCalculatorService.GetCategorizedItemOrTags(_selectedDataContext);

        _autoCalculatedSellItemIds = categorizedForAutoSell.ToSell
            .Where(itemOrTag => itemOrTag.GetCurrentUserPrice(_selectedDataContext) is not null)
            .Select(i => i.Id)
            .ToHashSet();

        _userElementsByElementId = _selectedDataContext.UserElements
            .GroupBy(ue => ue.ElementId)
            .ToDictionary(g => g.Key, g => g.First());

        if (_hideBlueprints)
        {
            _itemsToSellDisplay = _itemsToSellDisplay
                .Where(item => item.Elements.Any(e =>
                    e.IsProduct()
                    && _userElementsByElementId.TryGetValue(e.Id, out var ue)
                    && !ue.IsReintegrated
                    && !e.Recipe.IsBlueprint))
                .ToList();
        }

        _itemsToSellDisplay = _itemsToSellDisplay
            .Select(item => (Item: item, Element: GetBestRelatedElement(item)))
            .OrderBy(x => x.Element?.Recipe.Skill?.Name ?? "")
            .ThenBy(x => string.IsNullOrEmpty(x.Element?.Recipe.FamilyName)
                ? LocalizationService.GetTranslation(x.Item)
                : x.Element!.Recipe.FamilyName)
            .ThenBy(x => LocalizationService.GetTranslation(x.Item))
            .Select(x => x.Item)
            .ToList();

        _sellRowBucketIndices.Clear();
        var bucket = -1;
        Skill? prevSkill = null;
        var prevFamily = "";
        foreach (var item in _itemsToSellDisplay)
        {
            var element = GetBestRelatedElement(item);
            var skill = element?.Recipe.Skill;
            var family = element?.Recipe.FamilyName ?? "";
            var continuation = !string.IsNullOrEmpty(family) && skill == prevSkill && family == prevFamily;
            if (!continuation) bucket++;
            _sellRowBucketIndices[item.Id] = bucket;
            prevSkill = skill;
            prevFamily = family;
        }
    }

    private string GetStatusLabel()
    {
        if (_isLoadingData)
        {
            return LocalizationService.GetTranslation("PriceCalculator.Status.Loading");
        }

        if (IsCalculationInProgress)
        {
            return LocalizationService.GetTranslation("PriceCalculator.Status.Recalculating");
        }

        if (HasPendingManualCalculation)
        {
            return LocalizationService.GetTranslation("PriceCalculator.Status.RecalculationRequired");
        }

        return LocalizationService.GetTranslation("PriceCalculator.Status.Recalculating");
    }

    private async Task RequestCalculateFromRecipeDialog(string origin)
    {
        var triggerOrigin = origin switch
        {
            "UpdatePrice" => CalculateTriggerOrigin.PriceInput,
            "RoundFactorChange" or "ChangeReintegrate" or "UpdateShare" or "Equality" or "Equilibrate" or "FirstOnly" or "Honest" => CalculateTriggerOrigin.RecipeChange,
            _ => CalculateTriggerOrigin.RecipeChange,
        };

        await RequestCalculate(triggerOrigin);
    }

    private static string GetCalculationModeStorageKey(Guid dataContextId)
    {
        return $"{CalculationModeStorageKeyPrefix}:{dataContextId}";
    }

    private async Task<CalculationMode> GetStoredCalculationModeAsync(Guid dataContextId)
    {
        var storedValue = await LocalStorageService.GetItem(GetCalculationModeStorageKey(dataContextId));
        return Enum.TryParse<CalculationMode>(storedValue, out var calculationMode)
            ? calculationMode
            : CalculationMode.AutoSmart;
    }

