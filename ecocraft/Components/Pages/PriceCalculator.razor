                                            <MudStack Row Spacing="1" AlignItems="AlignItems.Center">
                                                <MudTooltip Text="@LocalizationService.GetTranslation(bestRecipeHasShare ? "PriceCalculator.RecipeTooltipWithShare" : "PriceCalculator.RecipeTooltip")">
