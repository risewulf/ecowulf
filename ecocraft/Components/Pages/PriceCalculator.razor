                                                            {
                                                                <img src="/assets/eco-icons/BlueprintItem_FG.png" alt="Blueprint" style="width: 24px; height: 24px;"/>
                                                            }
                                                            @if (!_showDetailedRecipes && relatedUserElements.Count > 1)
