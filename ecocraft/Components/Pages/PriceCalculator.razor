    private async Task UpdateCraftingTableFuel(UserCraftingTable userCraftingTable, Guid? fuelItemId)
    {
        if (userCraftingTable.FuelItemId == fuelItemId)
        {
            return;
        }

        var previousFuelItem = userCraftingTable.FuelItem;
        previousFuelItem?.UserCraftingTables.Remove(userCraftingTable);

        userCraftingTable.FuelItem = fuelItemId is null
            ? null
            : ContextService.CurrentServerData!.ItemOrTags.FirstOrDefault(item => item.Id == fuelItemId.Value);
        userCraftingTable.FuelItemId = userCraftingTable.FuelItem?.Id;
        if (userCraftingTable.FuelItem is not null
            && !userCraftingTable.FuelItem.UserCraftingTables.Contains(userCraftingTable))
        {
            userCraftingTable.FuelItem.UserCraftingTables.Add(userCraftingTable);
        }

        if (userCraftingTable.FuelItem is not null)
        {
            await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
            {
                UserServerDataService.AddUserPriceIfNotExists(context, _selectedDataContext!, userCraftingTable.FuelItem);
                return Task.CompletedTask;
            });
        }

        userCraftingTable.TotalCraftMinuteFee = CraftingTableFuelCostService.CalculateTotalCraftMinuteFee(_selectedDataContext!, userCraftingTable);

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            UserCraftingTableDbService.UpdateFuelItem(context, userCraftingTable);
            return Task.CompletedTask;
        });

        await RequestCalculate(CalculateTriggerOrigin.SettingsChange);
    }

