                                                    AutoCalculatedSellItemIds="@_autoCalculatedSellItemIds"
                                                    RowClassFunc="@OddIndexRowClass"
                                                    UpdatePriceCalculation="@UpdatePriceCalculation"
                                                    ShowItemOrTagDialog="@ShowItemOrTagDialog"
                                                    SetPrimaryUserPrice="@SetPrimaryUserPrice"
