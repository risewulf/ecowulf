    public void Dispose()
    {
        ContextService.OnHelpOverlayRequested -= ShowHelpOverlay;
        _calculateDebounceCts?.Cancel();
        _calculateDebounceCts?.Dispose();
        lock (_skillLevelSaveDebounceLock)
        {
            foreach (var cts in _skillLevelSaveDebounceBySkillId.Values)
            {
                cts.Cancel();
                cts.Dispose();
            }

            _skillLevelSaveDebounceBySkillId.Clear();
            _pendingSkillLevelBySkillId.Clear();
            _lastPersistedSkillLevelBySkillId.Clear();
        }

        ContextService.OnContextChanged -= OnContextChanged;

        if (_konamiRef is not null)
        {
            try { _ = JsRuntime.InvokeVoidAsync("konamiCode.unregister", _konamiRef).AsTask(); } catch { }
            _konamiRef.Dispose();
            _konamiRef = null;
        }
    }

    [JSInvokable]
    public async Task KonamiFillItemsToBuy()
    {
        if (_selectedDataContext is null) return;

        var random = new Random();
        var targets = new HashSet<UserPrice>();

        foreach (var itemOrTag in _itemsToBuyDisplay)
        {
            if (itemOrTag.IsTag)
            {
                foreach (var associatedItem in itemOrTag.AssociatedItems)
                {
                    var associatedUserPrice = associatedItem.GetCurrentUserPrice(_selectedDataContext);
                    if (associatedUserPrice is not null) targets.Add(associatedUserPrice);
                }
            }
            else
            {
                var userPrice = itemOrTag.GetCurrentUserPrice(_selectedDataContext);
                if (userPrice is not null) targets.Add(userPrice);
            }
        }

        var changed = new List<UserPrice>(targets.Count);
        foreach (var userPrice in targets)
        {
            decimal newValue = random.Next(1, 10);
            if (userPrice.Price == newValue) continue;
            userPrice.Price = newValue;
            changed.Add(userPrice);
        }

        if (changed.Count == 0) return;

        await EcoCraftDbContext.ContextSaveAsync(EcoCraftDbFactory, context =>
        {
            foreach (var userPrice in changed)
            {
                UserPriceDbService.UpdatePrice(context, userPrice);
            }
            return Task.CompletedTask;
        });

        await RequestCalculate(CalculateTriggerOrigin.PriceInput);

        StateHasChanged();
    }

