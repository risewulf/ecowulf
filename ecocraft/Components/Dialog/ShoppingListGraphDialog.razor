@using ecocraft.Models
@using ecocraft.Services
@implements IAsyncDisposable
@inject ShoppingListGraphService ShoppingListGraphService
@inject LocalizationService LocalizationService
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-grow-1">
            <MudText Typo="Typo.h6">
                @LocalizationService.GetTranslation("ShoppingList.ProductionChainTitle")
            </MudText>
            <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                @if (_hasContent)
                {
                    <MudTooltip Text="@LocalizationService.GetTranslation("ShoppingList.ProductionChainRecenter")">
                        <MudIconButton Icon="@MDIIcons.Filled.FitToScreen" OnClick="Recenter"/>
                    </MudTooltip>
                }
                <MudIconButton Icon="@MDIIcons.Filled.Close" OnClick="Close"/>
            </MudStack>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_hasContent)
        {
            <div id="@_containerId" class="shopping-list-graph-container"></div>
        }
        else
        {
            <MudStack Class="pa-8" Justify="Justify.Center" AlignItems="AlignItems.Center">
                <MudIcon Icon="@MDIIcons.Filled.Sitemap" Size="Size.Large"/>
                <MudText Typo="Typo.body1">@LocalizationService.GetTranslation("ShoppingList.ProductionChainEmpty")</MudText>
            </MudStack>
        }
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public DataContext ShoppingList { get; set; } = default!;

    private readonly string _containerId = "prod-graph-" + Guid.NewGuid().ToString("N");
    private ProductionGraphData? _data;
    private bool _hasContent;

    protected override void OnInitialized()
    {
        _hasContent = ShoppingList.UserRecipes.Count > 0;
        if (_hasContent)
        {
            _data = ShoppingListGraphService.BuildGraphData(ShoppingList);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _hasContent && _data is not null)
        {
            await JS.InvokeVoidAsync("ecoProductionGraph.render", _containerId, _data);
        }
    }

    private async Task Recenter()
    {
        if (_hasContent)
        {
            await JS.InvokeVoidAsync("ecoProductionGraph.fit", _containerId);
        }
    }

    private void Close() => MudDialog.Close();

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("ecoProductionGraph.dispose", _containerId);
        }
        catch (JSDisconnectedException)
        {
            // Le circuit est déjà fermé, rien à nettoyer côté client.
        }
    }
}
