@using Blazor.Diagrams.Components.Renderers;
@using ecocraft.Components.Utils
@using ecocraft.Diagram
@using ecocraft.Services
@inject LocalizationService LocalizationService

<div class="eco-graph-node">
    <div class="eco-graph-node-row">
        <span class="eco-graph-port"><PortRenderer @key="Node.Ports[0]" Port="@Node.Ports[0]"/></span>
        <EcoIcon Item="@Node.ItemOrTag" Size="64"/>
        <span class="eco-graph-port"><PortRenderer @key="Node.Ports[1]" Port="@Node.Ports[1]"/></span>
    </div>
    <div class="eco-graph-caption">
        <span class="eco-graph-caption-main">@LocalizationService.GetTranslation(Node.ItemOrTag)</span>
    </div>
</div>

@code {
    // This gets filled by the library
    [Parameter] public ItemNode Node { get; set; } = null!;
}
