    private static Guid? ResolveContextIdForSelect(List<EconomyPlayerContextOption> contexts, Guid? preferredContextId)
    {
        if (contexts.Count == 0)
        {
            return null;
        }

        if (preferredContextId is Guid contextId && contexts.Any(context => context.Id == contextId))
        {
            return contextId;
        }

        return contexts[0].Id;
    }

    private static EconomyPlayerContextOption? ResolveContextOptionForSelect(List<EconomyPlayerContextOption> contexts, Guid? selectedContextId)
    {
        if (selectedContextId is null)
        {
            return null;
        }

        return contexts.FirstOrDefault(context => context.Id == selectedContextId.Value);
    }

