    private async Task LoadDrilldownAsync(bool showLoadingIndicator = true, bool comparisonRowsOnly = false)
    {
        if (!CanOpenDrilldown
            || ServerId == Guid.Empty
            || CurrentUserServerId == Guid.Empty
            || _selectedPlayer1UserServerId is null
            || _selectedPlayer2UserServerId is null
            || _selectedPlayer1UserServerId == _selectedPlayer2UserServerId)
        {
            return;
        }

        try
        {
            if (showLoadingIndicator)
            {
                _isLoadingDrilldown = true;
                StateHasChanged();
            }

            var query = new EconomyPlayerDetailQuery
            {
                ServerId = ServerId,
                RequestingUserServerId = CurrentUserServerId,
                Player1UserServerId = _selectedPlayer1UserServerId.Value,
                Player2UserServerId = _selectedPlayer2UserServerId.Value,
                Player1DataContextId = _selectedPlayer1DataContextId,
                Player2DataContextId = _selectedPlayer2DataContextId,
                ComparisonBy = _comparisonBy,
                SortBy = EconomyComparisonSortBy.Entity,
                SortDescending = false,
                SearchText = string.Empty,
                OnlyDifferences = false,
                Page = 1,
                PageSize = 0
            };

            var result = await EconomyViewerService.GetPlayerDetailAsync(query);

            if (comparisonRowsOnly && _drilldown is not null)
            {
                _drilldown.ComparisonRows = result.ComparisonRows;
                _drilldown.TotalComparisonCount = result.TotalComparisonCount;
                _drilldown.Page = result.Page;
                _drilldown.PageSize = result.PageSize;
                _drilldown.GeneratedAtUtc = result.GeneratedAtUtc;
            }
            else
            {
                _drilldown = result;
                _selectedPlayer1DataContextId = ResolveContextIdForSelect(_drilldown.Player1Contexts, _drilldown.SelectedPlayer1DataContextId);
                _selectedPlayer2DataContextId = ResolveContextIdForSelect(_drilldown.Player2Contexts, _drilldown.SelectedPlayer2DataContextId);
                _selectedPlayer1ContextOption = ResolveContextOptionForSelect(_drilldown.Player1Contexts, _selectedPlayer1DataContextId);
                _selectedPlayer2ContextOption = ResolveContextOptionForSelect(_drilldown.Player2Contexts, _selectedPlayer2DataContextId);
            }
        }
        catch (UnauthorizedAccessException)
        {
            Snackbar.Add(LocalizationService.GetTranslation("EconomyViewer.Errors.Unauthorized"), Severity.Error);
            if (!comparisonRowsOnly)
            {
                _drilldown = null;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{LocalizationService.GetTranslation("EconomyViewer.Errors.LoadDrilldown")}: {ex.Message}", Severity.Error);
            if (!comparisonRowsOnly)
            {
                _drilldown = null;
            }
        }
        finally
        {
            if (showLoadingIndicator)
            {
                _isLoadingDrilldown = false;
            }

            StateHasChanged();
        }
    }

    private void CloseDrilldown()
    {
        _isOpen = false;
    }

    private bool FilterComparisonRow(EconomyPlayerComparisonRow row)
    {
        if (!_showComparisonIncompleteRows && EconomyViewerService.IsNoDataComparisonRow(row))
        {
            return false;
        }

        if (_comparisonOnlyDifferences && !row.IsDifferent)
        {
            return false;
        }

        if (_comparisonOnlyCommon && !EconomyViewerService.IsCommonComparisonRow(row))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(_comparisonSearch))
        {
            return true;
        }

        var search = _comparisonSearch.Trim();

        if (GetComparisonRowLabel(row).Contains(search, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var subLabel = GetComparisonRowSubLabel(row);
        return !string.IsNullOrWhiteSpace(subLabel) && subLabel.Contains(search, StringComparison.OrdinalIgnoreCase);
    }

    private Task OnComparisonOnlyDifferencesChanged(bool value)
    {
        _comparisonOnlyDifferences = value;
        if (value)
        {
            _comparisonOnlyCommon = false;
        }

        return Task.CompletedTask;
    }

    private Task OnComparisonOnlyCommonChanged(bool value)
    {
        _comparisonOnlyCommon = value;
        if (value)
        {
            _comparisonOnlyDifferences = false;
        }

        return Task.CompletedTask;
    }

    private async Task OnPlayer1ChangedInDrawer(Guid? value)
    {
        if (value is null)
        {
            return;
        }

        _selectedPlayer1UserServerId = value;
        if (_selectedPlayer2UserServerId == value)
        {
            _selectedPlayer2UserServerId = EconomyViewerService.GetFirstDifferentPlayerUserServerId(value.Value, AvailablePlayers);
        }

        if (_selectedPlayer2UserServerId is null)
        {
            return;
        }

        await PersistSelectedPlayer2Async(_selectedPlayer2UserServerId);
        _selectedPlayer1DataContextId = null;
        _selectedPlayer2DataContextId = null;
        _selectedPlayer1ContextOption = null;
        _selectedPlayer2ContextOption = null;
        await LoadDrilldownAsync();
    }

    private async Task OnPlayer2ChangedInDrawer(Guid? value)
    {
        if (value is null || _selectedPlayer1UserServerId is null || value == _selectedPlayer1UserServerId)
        {
            return;
        }

        _selectedPlayer2UserServerId = value;
        await PersistSelectedPlayer2Async(value);
        _selectedPlayer2DataContextId = null;
        _selectedPlayer2ContextOption = null;
        await LoadDrilldownAsync();
    }

    private async Task OnComparisonByChanged(EconomyComparisonEntity value)
    {
        _comparisonBy = value;
        await LoadDrilldownAsync(showLoadingIndicator: false, comparisonRowsOnly: true);
    }

    private async Task OnPlayer2ContextChanged(EconomyPlayerContextOption? value)
    {
        _selectedPlayer2ContextOption = value;
        _selectedPlayer2DataContextId = value?.Id;
        await LoadDrilldownAsync();
    }

    private async Task OnPlayer1ContextChanged(EconomyPlayerContextOption? value)
    {
        _selectedPlayer1ContextOption = value;
        _selectedPlayer1DataContextId = value?.Id;
        await LoadDrilldownAsync();
    }

    private async Task OnShowComparisonIncompleteRowsChanged(bool value)
    {
        _showComparisonIncompleteRows = value;
        await LocalStorageService.AddItem(ShowComparisonIncompleteRowsStorageKey, value.ToString());
    }

    private async Task ResetDrilldownFiltersAsync()
    {
        _comparisonBy = EconomyComparisonEntity.Item;
        _comparisonOnlyDifferences = false;
        _comparisonOnlyCommon = false;
        _showComparisonIncompleteRows = false;
        _comparisonSearch = string.Empty;
        await LocalStorageService.AddItem(ShowComparisonIncompleteRowsStorageKey, bool.FalseString);
        await LoadDrilldownAsync();
    }

