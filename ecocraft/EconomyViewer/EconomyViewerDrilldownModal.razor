    private IHasIconName? GetComparisonRowIcon(EconomyPlayerComparisonRow row)
    {
        if (row.ItemOrTagId is Guid itemId && ItemsById.TryGetValue(itemId, out var item))
        {
            return item;
        }

        if (row.RecipeId is Guid recipeId && RecipeProductItemsByRecipeId.TryGetValue(recipeId, out var recipeProductItem))
        {
            return recipeProductItem;
        }

        if (row.SkillId is Guid skillId && SkillsById.TryGetValue(skillId, out var skill))
        {
            return skill;
        }

        return null;
    }

    private static string GetComparisonRowFallbackIcon(EconomyPlayerComparisonRow row)
    {
        if (row.RecipeId is not null) return Icons.Material.Filled.Science;
        if (row.SkillId is not null) return Icons.Material.Filled.Handyman;
        if (row.IsTag == true) return Icons.Material.Filled.Tag;
        return Icons.Material.Filled.Inventory2;
    }

    private string GetComparisonRowLabel(EconomyPlayerComparisonRow row)
    {
        if (row.ItemOrTagId is Guid itemId && ItemsById.TryGetValue(itemId, out var item))
        {
            return LocalizationService.GetTranslation(item);
        }

        if (row.RecipeId is Guid recipeId && RecipesById.TryGetValue(recipeId, out var recipe))
        {
            return LocalizationService.GetTranslation(recipe);
        }

        if (row.SkillId is Guid skillId && SkillsById.TryGetValue(skillId, out var skill))
        {
            return LocalizationService.GetTranslation(skill);
        }

        return row.EntityName;
    }

    private string? GetComparisonRowSubLabel(EconomyPlayerComparisonRow row)
    {
        if (row.RecipeId is not null && row.SecondaryLabel is not null)
        {
            if (row.SkillId is Guid skillId && SkillsById.TryGetValue(skillId, out var skill))
            {
                return LocalizationService.GetTranslation(skill);
            }

            return row.SecondaryLabel;
        }

        return null;
    }

